# ---------- Database ----------
POSTGRES_USER=glucia
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=glucia
DATABASE_URL=postgresql://glucia:change-me-strong-password@localhost:5432/glucia?schema=public

# ---------- Auth ----------
JWT_ACCESS_SECRET=change-me-64-chars-random
JWT_REFRESH_SECRET=change-me-other-64-chars-random
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ---------- AI ----------
# اگر خالی باشد، سیستم به‌صورت خودکار از پاسخ‌های Mock استفاده می‌کند
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- App ----------
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- Notifications (اختیاری) ----------
SMS_PROVIDER_API_KEY=
TELEGRAM_BOT_TOKEN=
SMTP_URL=

# ---------- Payments (اختیاری — بدون آن حالت Mock) ----------
ZARINPAL_MERCHANT_ID=
PAYMENT_CALLBACK_URL=http://localhost:3000/payment/callback

# ---------- Push & CGM (اختیاری) ----------
FCM_SERVER_KEY=
CGM_WEBHOOK_SECRET=
